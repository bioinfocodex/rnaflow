{
  "name": "rnaflow",
  "productName": "RNAflow",
  "version": "1.0.0",
  "description": "Complete RNA-seq analysis pipeline — from raw FASTQ to publication figures",
  "author": {
    "name": "BioInfoCodex",
    "email": "hello@bioinfocodex.com",
    "url": "https://bioinfocodex.com"
  },
  "license": "MIT",
  "homepage": "https://bioinfocodex.com",
  "main": "main.js",
  "scripts": {
    "start":       "electron .",
    "dev":         "NODE_ENV=development electron .",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all":   "electron-builder --mac --win --linux",
    "dist":        "electron-builder"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.bioinfocodex.rnaflow",
    "productName": "RNAflow",
    "copyright": "© 2025 BioInfoCodex",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "RNAflow_App.html",
      "rnaflow_server.py",
      "!node_modules/.cache"
    ],
    "extraResources": [
      { "from": "rnaflow_server.py", "to": "rnaflow_server.py" }
    ],

    "mac": {
      "category": "public.app-category.education",
      "hardenedRuntime": false,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RNAflow"
    },

    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },

    "deb": {
      "depends": ["python3"]
    },

    "linux": {
      "category": "Education",
      "description": "Complete RNA-seq analysis pipeline",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ]
    },

    "publish": {
      "provider": "github",
      "owner":    "bioinfocodex",
      "repo":     "rnaflow"
    }
  }
}
